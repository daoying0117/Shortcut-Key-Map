{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Shortcut Key Map",
  "version": "0.1.0",
  "identifier": "com.daoying.shortcutkeymap",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Shortcut Key Map",
        "width": 1280,
        "height": 960,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "transparent": true,
        "decorations": false,
        "windowEffects": {
          "effects": [
            "contentBackground"
          ],
          "radius": 22
        },
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
